rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }
    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function isOwner() {
      return signedIn() && userDoc().role == 'owner';
    }
    function isStaff() {
      return signedIn() && userDoc().role == 'staff';
    }
    function staffBranch() {
      return userDoc().staffBranch;
    }

    // ---- users ----
    match /users/{id} {
      allow read: if signedIn() && (resource.data.uid == request.auth.uid || isOwner());
      allow create: if signedIn() && request.auth.uid == request.resource.data.uid;
      allow update: if signedIn() && (resource.data.uid == request.auth.uid || isOwner());
      allow delete: if isOwner();
    }

    // ---- branches ----
    match /branches/{id} {
      allow read: if signedIn();
      allow write: if isOwner();
    }

    // ---- services ----
    match /services/{id} {
      allow read: if signedIn();
      allow write: if isOwner();
    }

    // ---- offers ----
    match /offers/{id} {
      allow read: if signedIn();
      allow write: if isOwner();
    }

    // ---- appointments ----
    match /appointments/{id} {
      allow read: if signedIn() && (
        resource.data.customerUid == request.auth.uid ||
        isOwner() ||
        (isStaff() && resource.data.branchId == staffBranch())
      );
      allow create: if signedIn() && (
        request.resource.data.customerUid == request.auth.uid || isOwner() || isStaff()
      );
      allow update, delete: if signedIn() && (
        isOwner() || (isStaff() && resource.data.branchId == staffBranch())
      );
    }

    // ---- notifications ----
    match /notifications/{id} {
      allow read: if signedIn() && (
        resource.data.recipientUid == request.auth.uid ||
        resource.data.audience == userDoc().role ||
        (resource.data.branchId == staffBranch())
      );
      allow create: if signedIn();
      allow update: if signedIn() && resource.data.recipientUid == request.auth.uid;
      allow delete: if isOwner();
    }

    // ---- settings ----
    match /settings/{id} {
      allow read: if signedIn();
      allow write: if isOwner();
    }
  }
}
